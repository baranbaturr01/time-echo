; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be edited manually.

[application]

config/name="TIME ECHO"
config/description="A grid-based puzzle game where you collaborate with your past selves (echoes) to solve levels."
run/main_scene="res://scenes/levels/level_1.tscn"
config/features=PackedStringArray("4.3", "Mobile")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://scripts/autoload/game_manager.gd"

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/size/mode=2
window/stretch/mode="viewport"
window/stretch/aspect="keep_height"
window/handheld/orientation=1

